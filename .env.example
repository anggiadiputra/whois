# Example environment variables. Do NOT store real secrets here.
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
VITE_NEON_AUTH_URL=https://your-neon-auth-url.example
NEON_AUTH_REAL_URL=https://your-real-url.example
NEON_AUTH_JWKS_URL=https://your-jwks-url.example
SERVER_ENCRYPTION_SECRET=your-server-encryption-secret

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM="Your App <no-reply@example.com>"

OTP_EXPIRES_MINUTES=10
IDLE_TIMEOUT_MINUTES=30
VITE_IDLE_TIMEOUT_MINUTES=30
